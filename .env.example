# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/ishbot"

# MTProto (my.telegram.org dan olish)
API_ID=your_api_id
API_HASH=your_api_hash

# Birinchi marta auth qilgandan keyin konsolda chiqadi
SESSION_STRING="asduigdfg9qe8wegq9gfwep9fadgfiads"

# Telegraf bot (@BotFather dan)
BOT_TOKEN="your_bot_token"

NODE_ENV=development

# Admin Telegram ID lari (vergul bilan ajratib)
ADMIN_IDS=123456789,987654321

PORT=3000

# AI — provayder-agnostik (OpenAI-mos API)
#   DeepSeek : https://api.deepseek.com  | deepseek-chat
#   OpenAI   : https://api.openai.com/v1 | gpt-4o-mini
#   Gemini   : https://generativelanguage.googleapis.com/v1beta/openai | gemini-2.5-flash
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
