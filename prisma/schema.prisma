generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique
  username   String?
  firstName  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  filters       Filter[]
  notifications Notification[]
}

model Filter {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  keywords  String[] // expanded lowercase keywords (react, reactjs, react.js, ...)
  location  String?  // comma-separated location keywords yoki null
  workType  String?  // "remote"|"office"|"hybrid"|null
  level     String?  // "intern"|"junior"|"middle"|"senior"|"lead"|null
  minSalary Int?     // minimal maosh so'mda
  fieldKey  String?  // "frontend"|"backend"|... (display uchun)
  fieldLabel String? // "Frontend", "Backend" (display uchun)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [telegramId], onDelete: Cascade)

  @@index([userId])
}

model Vacancy {
  id              Int      @id @default(autoincrement())
  text            String
  channel         String
  messageId       BigInt   @unique
  title           String?
  company         String?
  location        String?
  salary          String?
  salaryMin       Int?
  salaryMax       Int?
  technologies    String[]
  telegramContact String?
  phone           String?
  workType        String?  // "remote"|"office"|"hybrid"
  level           String?  // "junior"|"middle"|"senior"
  jobType         String?  // "vacancy"|"resume"
  messageLink     String?  // https://t.me/channelname/messageId
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  notifications Notification[]

  @@index([channel])
  @@index([createdAt])
  @@index([technologies])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    BigInt
  vacancyId Int
  sentAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [telegramId], onDelete: Cascade)
  vacancy Vacancy @relation(fields: [vacancyId], references: [id],      onDelete: Cascade)

  @@unique([userId, vacancyId])
  @@index([userId])
  @@index([vacancyId])
}
